      "source": [
        "# TIME AXIS (timestamps)\n",
        "\n",
        "start = datetime.datetime(2025, 1, 1, 0, 0, 0)  # simulation start timestamp\n",
        "timestamps = [  # build timestamp list of length TIMESTEPS\n",
        "    start + datetime.timedelta(minutes=i * timestep_minutes)\n",
        "    for i in range(TIMESTEPS)\n",
        "]"
