        "# SIMULATION STATE (thermal + attitude)\n",
        "\n",
        "temps = np.full(6, 20.0)  # initialize 6 face temperatures (°C)\n",
        "\n",
        "# Attitude drift: slow change to avoid identical illumination patterns each orbit\n",
        "# Here: 1 full revolution (2π rad) every 7 days\n",
        "attitude_rate = 2 * math.pi / (24 * 60 * 7)  # radians per minute\n",
        "attitude = 0.0  # initial orientation angle (radians)\n",
        "\n",
        "rows = []  # we store each timestep as a row dict, later convert to DataFrame\n"
      ],
