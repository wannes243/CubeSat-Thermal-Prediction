      "cell_type": "code",
      "source": [
        "# AUXILIARY FUNCTIONS\n",
        "\n",
        "def orbital_phase_minute(idx: int) -> int:\n",
        "    # Purpose: convert global time index into minute-within-orbit\n",
        "    # Example: ORBIT_PERIOD_MIN=90 => values cycle in [0..89]\n",
        "    return (idx * timestep_minutes) % ORBIT_PERIOD_MIN\n",
        "\n",
        "\n",
        "def in_sun(orbit_min: int) -> bool:\n",
        "    # Purpose: eclipse model (simplified)\n",
        "    # Assumption: spacecraft is sunlit during the first SUNLIT_DURATION_MIN of each orbit\n",
        "    return 0 <= orbit_min < SUNLIT_DURATION_MIN\n",
        "\n",
        "\n",
        "def face_incidence(orbit_min: int, face_index: int, attitude_offset: float = 0.0) -> float:\n",
        "    # Purpose: compute a coefficient in [0,1] indicating solar flux fraction on a face\n",
        "    # - 0.0 means no illumination (face away from sun or shadow)\n",
        "    # - 1.0 means maximum illumination (face aligned with sun direction)\n",
        "    # Model: cosine-based incidence (toy geometry)\n",
        "    base_phase = (face_index / 6.0) * 2 * math.pi  # assign each face an angular direction\n",
        "    orb_phase = (orbit_min / ORBIT_PERIOD_MIN) * 2 * math.pi  # orbit time mapped to [0..2π]\n",
        "    val = math.cos(orb_phase - base_phase - attitude_offset)  # alignment ~ cos(angle difference)\n",
        "    return max(0.0, val)  # clamp negatives: no \"negative sunlight\""
      ],
      "metadata": {
        "id": "HXD5ZtPmVmQ4"
      },
      "execution_count": null,
