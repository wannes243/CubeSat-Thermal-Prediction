        "# DEFINE LSTM MODEL (multi-output regression)\n",
        "class LSTMTempModel(nn.Module):\n",
        "    # Purpose: map a sequence of telemetry windows to future face temperatures (6 outputs)\n",
        "    def __init__(self, input_size: int, hidden_size: int = 32, num_layers: int = 1, output_size: int = 6):\n",
        "        super().__init__()  # initialize nn.Module base class\n",
        "\n",
        "        # LSTM layer:\n",
        "        # - input: (batch, seq_len, input_size)\n",
        "        # - output: (batch, seq_len, hidden_size)\n",
        "        self.lstm = nn.LSTM(\n",
        "            input_size=input_size,\n",
        "            hidden_size=hidden_size,\n",
        "            num_layers=num_layers,\n",
        "            batch_first=True,\n",
        "        )\n",
        "\n",
        "        # Linear head:\n",
        "        # - takes last hidden state and outputs 6 predicted temperatures\n",
        "        self.fc = nn.Linear(hidden_size, output_size)\n",
        "\n",
        "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",
        "        # x shape: (batch, seq_len, features)\n",
        "        out, _ = self.lstm(x)  # out shape: (batch, seq_len, hidden_size)\n",
        "        last = out[:, -1, :]  # take last time step representation (batch, hidden_size)\n",
        "        y_hat = self.fc(last)  # (batch, 6)\n",
        "        return y_hat\n",
        "\n",
        "\n",
        "# Instantiate model using feature dimension from training data\n",
        "input_size = X_train_t.shape[2]\n",
        "model = LSTMTempModel(input_size=input_size, hidden_size=32, num_layers=1, output_size=6).to(DEVICE)"
      ],
