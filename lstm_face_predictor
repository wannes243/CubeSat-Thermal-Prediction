        "# GLOBAL PARAMETERS\n",
        "YEARS = 1  # number of simulated years\n",
        "timestep_minutes = 1  # sampling resolution in minutes (1 sample per minute)\n",
        "\n",
        "# Total timesteps = minutes per year * number of years / sampling step\n",
        "# 365 days/year * 24 hours/day * 60 minutes/hour = 525,600 minutes/year\n",
        "TIMESTEPS = int(365 * 24 * 60 / timestep_minutes * YEARS)\n",
        "\n",
        "ORBIT_PERIOD_MIN = 90  # orbital period (minutes), simplified LEO value\n",
        "SUNLIT_DURATION_MIN = 60  # minutes in sun per orbit, simplified eclipse model\n",
        "\n",
        "SENSOR_NOISE_STD_TEMP = 0.25  # measurement noise for temperature (°C)\n",
