        "RNG_SEED = 42  # random seed for reproducibility\n",
        "\n",
        "# --- Simple thermal dynamics constants (toy model) ---\n",
        "HEATING_RATE_SUN = 0.08  # °C/min when a face receives full solar incidence (coefficient)\n",
        "COOLING_RATE_FACTOR = 0.0015  # proportional cooling factor (toy approximation)\n",
        "INTERNAL_HEAT_BASE = 0.02  # °C/min baseline internal dissipation\n",
        "RADIO_HEAT_ADDITION = 0.4  # °C/min added dissipation when radio is ON\n",
        "\n",
        "# --- Simple power / telemetry constants (toy model) ---\n",
        "SOLAR_CURRENT_FULL = 150.0  # mA per \"fully illuminated face coefficient sum\"\n",
        "BATTERY_BASE_DRAW = 45.0  # mA baseline consumption\n",
        "RADIO_DRAW = 100.0  # mA extra draw when radio is ON\n",
