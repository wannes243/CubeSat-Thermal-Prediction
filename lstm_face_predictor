      "cell_type": "code",
      "source": [
        "#  SYNTHETIC DATA GENERATION LOOP\n",
        "\n",
        "print(\"Generating synthetic dataset (may take time for 1-year at 1-min resolution)...\")\n",
        "\n",
        "for idx in tqdm(range(TIMESTEPS)):  # iterate over each minute\n",
        "    orb_min = orbital_phase_minute(idx)  # minute-within-orbit (0..89)\n",
        "    sun_flag = 1 if in_sun(orb_min) else 0  # convert bool to {0,1} for ML features\n",
        "\n",
        "    # Radio schedule (toy): radio transmits during minutes (1..9) of each orbit\n",
        "    radio_on = 1 if 0 < orb_min < 10 else 0\n",
        "\n",
        "    # Update attitude slowly (toy drift)\n",
        "    attitude += attitude_rate * timestep_minutes  # increment angle by rate * dt\n",
        "    if attitude > 2 * math.pi:  # keep angle bounded\n",
        "        attitude -= 2 * math.pi\n",
        "\n",
        "    # Solar incidence coefficient per face (0..1)\n",
        "    incidences = np.array([face_incidence(orb_min, f, attitude) for f in range(6)])\n",
        "\n",
        "    # If spacecraft in eclipse, no solar incidence on any face\n",
        "    if not sun_flag:\n",
        "        incidences[:] = 0.0\n",
        "\n",
        "    # Solar heating contribution per face (°C/min)\n",
        "    solar_inputs = incidences * HEATING_RATE_SUN\n",
        "\n",
        "    # Internal heating per face (°C/min), baseline plus occasional events\n",
        "    internal_heats = np.full(6, INTERNAL_HEAT_BASE)\n",
        "\n",
        "    # Occasional electronics activity on some faces (toy bursts)\n",
        "    if idx % (ORBIT_PERIOD_MIN * 20) < 5:  # burst pattern on face 0\n",
        "        internal_heats[0] += 0.05\n",
        "    if idx % (ORBIT_PERIOD_MIN * 15) < 7:  # burst pattern on face 1\n",
        "        internal_heats[1] += 0.03\n",
        "\n",
        "    # Add radio heating on one face (toy mapping: face 2)\n",
        "    if radio_on:\n",
        "        internal_heats[2] += RADIO_HEAT_ADDITION\n",
        "\n",
        "    # Cooling losses (toy): proportional to current temperature\n",
        "    # Interpretation: hotter surfaces radiate more and thus lose more heat\n",
        "    heat_out = COOLING_RATE_FACTOR * temps\n",
        "\n",
        "    # Euler integration step (Temp_{t+1} = Temp_t + (inputs - outputs))\n",
        "    delta_temps = solar_inputs + internal_heats - heat_out\n",
        "    temps = temps + delta_temps\n",
        "\n",
        "    # Add sensor measurement noise (what we store is \"measured\" temp, not perfect true temp)\n",
        "    measured_temps = temps + np.random.normal(0, SENSOR_NOISE_STD_TEMP, size=6)\n",
        "\n",
        "    # System-level currents (toy telemetry)\n",
        "    solar_current = (np.sum(incidences) * SOLAR_CURRENT_FULL) + np.random.normal(0, SENSOR_NOISE_STD_AMP)\n",
        "    battery_draw = (BATTERY_BASE_DRAW + radio_on * RADIO_DRAW) + np.random.normal(0, SENSOR_NOISE_STD_AMP)\n",
        "\n",
        "    # Distance (toy): small periodic variation around 700 km\n",
        "    distance_km = 700 + 10 * math.sin(2 * math.pi * idx / (ORBIT_PERIOD_MIN * 10))\n",
        "\n",
        "    # Build one telemetry row (one minute)\n",
        "    row = {\n",
        "        \"timestamp\": timestamps[idx].isoformat(),  # ISO timestamp string\n",
        "        \"orbital_minute\": orb_min,  # minute in orbit\n",
        "        \"is_sunlit\": sun_flag,  # 0/1 sunlight state\n",
        "        \"radio_on\": radio_on,  # 0/1 operational mode\n",
        "        \"solar_current_mA\": solar_current,  # solar current telemetry\n",
        "        \"battery_draw_mA\": battery_draw,  # load telemetry\n",
        "        \"distance_km\": distance_km,  # orbital distance proxy\n",
        "    }\n",
        "\n",
        "    # Store face temperatures as separate columns\n",
        "    for f in range(6):\n",
        "        row[f\"temp_face_{f+1}\"] = measured_temps[f]\n",
        "\n",
        "    rows.append(row)  # append row to dataset list"
